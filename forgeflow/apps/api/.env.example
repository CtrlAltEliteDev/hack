# Free tier (recommended): Groq — https://console.groq.com/keys
GROQ_API_KEY=
# Optional override; default for Groq is llama-3.1-8b-instant
# LLM_MODEL=llama-3.1-8b-instant

# Paid / other: OpenAI (leave GROQ_API_KEY empty)
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
# LLM_MODEL=gpt-4o-mini

# Per-request HTTP read timeout (seconds) for each LLM call — multi-step workflow needs headroom
# LLM_HTTP_TIMEOUT_SECONDS=900
